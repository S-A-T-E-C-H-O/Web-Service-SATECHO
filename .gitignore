# Firebase / Service accounts (proteger claves JSON)
# Ignorar archivo concreto que has añadido
/src/main/resources/firebase-service-account.json
# O, si prefieres ignorar cualquier json de service-account:
# src/main/resources/*service-account*.json

# Spring Boot / application secrets
# Si tus application-*.yml contienen secretos, ignóralos aquí y mantén plantillas en el repo
/src/main/resources/application-dev.yml
/src/main/resources/application-prod.yml
/src/main/resources/application.properties

